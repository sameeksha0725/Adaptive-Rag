# Required environment variables for Adaptive RAG

# Ollama model name for local LLM inference
OLLAMA_MODEL=qwen3:latest

# Embedding model identifier
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Cross-encoder reranker model
RERANKER_MODEL=BAAI/bge-reranker-base

# Enable or disable CrossEncoder reranking
USE_RERANKER=true

# Number of documents retrieved per retriever before reranking
RETRIEVAL_TOP_K=20

# Number of final documents passed to the LLM
FINAL_TOP_K=5

# Reciprocal Rank Fusion parameter
RRF_K=60

# Retries and service configuration
MAX_RETRIES=2

# Database and external service configuration
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=adaptive_rag
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_CODE_COLLECTION=codebase
QDRANT_DOCS_COLLECTION=guidelines
TAVILY_API_KEY=
